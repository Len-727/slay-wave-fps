// ============================================================
//  FullscreenQuadVS.hlsl
//  フルスクリーンクワッド頂点シェーダー(ポストプロセス共通)
//
//  【何をしてるか？】
//  画面全体を覆う四角形を、頂点バッファなしで生成する。
//  SV_VertexIDだけで3頂点の三角形を作り、画面を埋める。
//
//  【使い方】
//  Draw(3, 0) で呼び出す。3頂点で画面全体をカバーする大きな三角形。
// ============================================================

struct VSOutput
{
    float4 position : SV_POSITION; // クリップ空間の位置
    float2 texcoord : TEXCOORD0; // UV座標(0~1)
};

VSOutput main(uint vertexID : SV_VertexID)
{
    VSOutput output;

    // === 3頂点で画面全体を覆う大きな三角形を生成 ===
    //
    //  頂点0: (-1, +3) → UV(0, -1)  ← 画面の上の遥か外
    //  頂点1: (-1, -1) → UV(0,  1)  ← 画面の左下
    //  頂点2: (+3, -1) → UV(2,  1)  ← 画面の右の遥か外
    //
    //  この三角形は画面(0~1 x 0~1)を完全にカバーする。
    //  はみ出た部分はラスタライザーが自動でクリップ。

    // UV座標を頂点IDから計算
    output.texcoord = float2(
        (vertexID == 2) ? 2.0f : 0.0f, // 頂点2だけX=2、他はX=0
        (vertexID == 0) ? -1.0f : 1.0f // 頂点0だけY=-1、他はY=1
    );

    // UV → クリップ空間に変換
    output.position = float4(
        output.texcoord.x * 2.0f - 1.0f, // 0~2 → -1~+3
        1.0f - output.texcoord.y * 2.0f, // Y反転(DX座標系)
        0.0f, // 深度=0(最前面)
        1.0f // w=1
    );

    return output;
}
